# ─── WhatsApp ────────────────────────────────────────────────────────────────
# Nomor yang diizinkan (fallback jika Supabase belum dikonfigurasi)
# Format: internasional tanpa + → 6281234567890,6289876543210
ALLOWED_WA_NUMBERS=

# Path penyimpanan session WhatsApp (default: ./session)
WA_SESSION_PATH=./session

# ─── AI Provider ─────────────────────────────────────────────────────────────
# Pilih salah satu: openrouter | claude | openai | ollama
AI_PROVIDER=openrouter

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-xxxx
OPENROUTER_MODEL=openai/gpt-4o-mini

# Anthropic Claude (https://console.anthropic.com)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama (lokal saja, tidak bisa untuk production)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Dari: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Multi-store (opsional) ───────────────────────────────────────────────────
# Isi jika bot ini khusus untuk satu toko (lihat Stores → Store ID di dashboard)
# Kosongkan jika 1 bot untuk semua toko
BOT_STORE_ID=

# ─── Lainnya ─────────────────────────────────────────────────────────────────
# Port health-check server (default: 3001) — tidak perlu diubah untuk VPS
PORT=3001
